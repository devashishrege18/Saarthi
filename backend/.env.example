# SAARTHI Environment Configuration

# Claude API
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Database
DATABASE_PATH=data/saarthi.db

# File Storage
UPLOAD_DIR=uploads

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Trust Score Thresholds
AUTO_APPROVE_THRESHOLD=0.85
AUTO_REJECT_THRESHOLD=0.50

# Trust Score Weights (must sum to 1.0)
WEIGHT_EXTRACTION=0.35
WEIGHT_VALIDATION=0.30
WEIGHT_HISTORICAL=0.20
WEIGHT_FRAUD=0.15
