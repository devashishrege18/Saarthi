# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "ollama" (default, free), "claude", "openai_compatible"
LLM_PROVIDER=ollama

# ─── Ollama (default — free, local) ──────────────────────────────────────────
# Install: https://ollama.com → then run: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─── Claude (optional — requires paid API key) ──────────────────────────────
# CLAUDE_API_KEY=your-claude-api-key-here
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── OpenAI-compatible (optional — Groq, Together, OpenAI, etc.) ─────────────
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# ─── General ──────────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=4096
DEBUG=true

# ─── Trust Score Thresholds ───────────────────────────────────────────────────
AUTO_APPROVE_THRESHOLD=0.85
AUTO_REJECT_THRESHOLD=0.50
